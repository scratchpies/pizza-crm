# Postgres connection string from Neon (https://neon.tech) - free tier is plenty for this app.
# Use the "pooled connection" string Neon gives you.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# The password you'll use to log into the CRM. Change this to something only you know.
ADMIN_PASSWORD="change-me"

# Random secret used to sign login sessions. Generate one with:
#   openssl rand -hex 32
SESSION_SECRET="change-me-too"

# Optional: only needed if you've turned on 2FA (npm run setup-2fa). Leave
# this unset/commented out and login works with just ADMIN_PASSWORD.
# TOTP_SECRET="paste-the-secret-setup-2fa-prints"
